  "keyFeatures": [
    "Student lifecycle management — admissions, enrollment, status tracking, and fee history",
    "Fee collection with 70/30 teacher/academy revenue split, receipt generation, and balance enforcement",
    "Gatekeeper barcode-scanning entry system with real-time attendance auto-marking",
    "Role-based access control with OWNER, PARTNER, STAFF, and OPERATOR roles",
    "Teacher payroll management with unverified/verified cash flow and payout requests",
    "Student self-service portal with profile picture upload and fee/attendance visibility",
    "Daily closing workflow — FLOATING transactions verified and reconciled by staff",
    "Timetable, sessions, and class scheduling with subject-teacher assignment",
    "Inventory tracking for academy assets and supplies",
    "Lead and admissions pipeline with registration approval workflow"
  ],
